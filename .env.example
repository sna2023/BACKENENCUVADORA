APP_NAME=UniIncubadora
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://backenencuvadora-2.onrender.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_EC

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── Database ────────────────────────────────────────────────────
# Local: DB_CONNECTION=sqlite (sin host/port/user/pass)
# Render: DB_CONNECTION=pgsql (llenar con datos de PostgreSQL de Render)
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# ─── CORS & Sanctum ──────────────────────────────────────────────
ALLOWED_ORIGINS=https://fronteencuvadora.onrender.com
SANCTUM_STATEFUL_DOMAINS=fronteencuvadora.onrender.com
FRONTEND_URL=https://fronteencuvadora.onrender.com

# ─── Sessions ────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ─── Cache / Queue ───────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ─── Mail ────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@uniincubadora.edu.ec"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
